{
  "name": "@opencrowd/local-api",
  "version": "0.1.0",
  "description": "Localhost HTTP API integration for OpenCrowd tools.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sr33j/opencrowd.git",
    "directory": "packages/local-api"
  },
  "bugs": {
    "url": "https://github.com/sr33j/opencrowd/issues"
  },
  "homepage": "https://github.com/sr33j/opencrowd#readme",
  "keywords": [
    "opencrowd",
    "local-api",
    "x402"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opencrowd/core": "0.1.0"
  },
  "scripts": {
    "build": "tsc -b",
    "prepack": "npm run build"
  }
}
